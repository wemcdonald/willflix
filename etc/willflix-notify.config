# willflix-notify configuration
# This is the repo default. To override values (e.g. credentials),
# create ~/.config/willflix-notify/config with just the overrides.

# Pushover credentials (override in ~/.config/willflix-notify/config)
PUSHOVER_APP_TOKEN=""
PUSHOVER_USER_KEY=""

# Email recipient for alerts
NOTIFY_EMAIL=""

# Dedup: suppress repeat alerts for a window based on severity.
# Checks still run at their normal frequency, but you only get re-notified
# after the debounce window expires. Per-call --dedup-window overrides these.
DEDUP_DIR="/var/tmp/willflix-notify"
DEDUP_WINDOW_CRITICAL="1h"
DEDUP_WINDOW_WARNING="4h"
DEDUP_WINDOW_INFO="24h"

# External watchdog ping URLs (set one or both)
# healthchecks.io: free, outbound ping — https://healthchecks.io
HEALTHCHECKS_PING_URL=""
# UptimeRobot: free, but inbound HTTP monitoring — https://uptimerobot.com
UPTIMEROBOT_HEARTBEAT_URL=""

# Monitor freshness — monitoring scripts touch files here on success
MONITOR_FRESHNESS_DIR="/var/tmp/willflix-monitors"

# Media app API endpoints
SONARR_URL="http://localhost:8989/sonarr"
RADARR_URL="http://localhost:7878/radarr"
NZBGET_URL="http://localhost:6789"

# LLM for media change classification
LLM_PROVIDER="anthropic"
LLM_MODEL="claude-haiku-4-5-20251001"

# Media health check thresholds
MEDIA_FAILED_IMPORT_THRESHOLD=3    # alert if more than N failures in 24h
MEDIA_QUEUE_STUCK_HOURS=6          # alert if queue errors older than N hours
MEDIA_INACTIVITY_DAYS=7            # alert if no successful imports in N days
