LABEL=MediaD        /Volumes/MediaD          ext4    defaults,nofail,x-systemd.device-timeout=30s,x-systemd.mount-timeout=30s        0       2
LABEL=MediaE        /Volumes/MediaE          ext4    defaults,nofail,x-systemd.device-timeout=30s,x-systemd.mount-timeout=30s        0       2
LABEL=MediaF        /Volumes/MediaF          ext4    defaults,nofail,x-systemd.device-timeout=30s,x-systemd.mount-timeout=30s        0       2
LABEL=MediaG        /Volumes/MediaG          ext4    defaults,nofail,x-systemd.device-timeout=30s,x-systemd.mount-timeout=30s        0       2
LABEL=MediaH        /Volumes/MediaH          ext4    defaults,nofail,x-systemd.device-timeout=30s,x-systemd.mount-timeout=30s        0       2
LABEL=MediaI        /Volumes/MediaI          ext4    defaults,nofail,x-systemd.device-timeout=30s,x-systemd.mount-timeout=30s        0       2
LABEL=MediaJ        /Volumes/MediaJ          ext4    defaults,nofail,x-systemd.device-timeout=30s,x-systemd.mount-timeout=30s        0       2
