[Unit]
Description=Webhook Handler
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory=/docker/config
ExecStart=/usr/bin/docker compose up -d webhook-handler
ExecStop=/usr/bin/docker compose stop webhook-handler
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target