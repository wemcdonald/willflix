[Unit]
Description=Healthbot Monitoring
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory=/docker/config
ExecStart=/usr/bin/docker compose up -d healthbot
ExecStop=/usr/bin/docker compose stop healthbot
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target