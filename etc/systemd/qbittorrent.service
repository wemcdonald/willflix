[Unit]
Description=QBittorrent
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory=/willflix/docker
ExecStart=/usr/bin/docker compose up -d qbittorrent
ExecStop=/usr/bin/docker compose down qbittorrent
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
