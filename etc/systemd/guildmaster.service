[Unit]
Description=Guildmaster
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory=/docker/config
ExecStart=/usr/bin/docker compose up -d guildmaster
ExecStop=/usr/bin/docker compose down guildmaster
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
