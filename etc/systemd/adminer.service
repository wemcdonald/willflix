[Unit]
Description=Adminer Database Management
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory=/willflix/docker
ExecStart=/usr/bin/docker compose up -d adminer
ExecStop=/usr/bin/docker compose stop adminer
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target