[Unit]
Description=Nextcloud
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory=/willflix/docker
ExecStart=/usr/bin/docker compose up -d nextcloud
ExecStop=/usr/bin/docker compose stop nextcloud
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target