[Unit]
Description=Calibre Web Automated
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory=/willflix/docker
ExecStart=/usr/bin/docker compose up -d calibre-web-automated
ExecStop=/usr/bin/docker compose stop calibre-web-automated
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target