MAILTO=will

# TEMPORARY (added 2026-06-15, hang investigation): sample CPU temp/load every
# minute + IPMI voltages/PSU every 5 min, to catch what the next freeze looks like
# under load. NOT wrapped in willflix-cron (raw sampler, no alerting/freshness needed).
# Remove this line + /willflix/bin/log-thermals once the hang cause is confirmed.
# See docs/hang-investigation-2026-06-15.md.
* * * * * /willflix/bin/log-thermals

# TEMPORARY (added 2026-06-15, hardware sizing): sample Plex transcode count vs
# CPU + transcode-ramdisk high-water-mark every 2 min, to size a replacement
# MB/CPU/RAM. Raw sampler (no willflix-cron wrapper) — writes its own CSV to
# /willflix/log/plex-capacity/. Remove this line once the new hardware is chosen.
# See docs/hardware-sizing-2026-06.md.
*/2 * * * * /willflix/bin/cron/log_plex_capacity >/dev/null

# Snapraid - daily sync (Mon-Sat 1am), weekly sync+scrub (Sun 1am)
# Snapraid sync — RE-ENABLED 2026-06-21 on new hardware (old PSU/01:00-hang cause gone).
# GATE: run a baseline `sudo snapraid sync` once (fresh root-SSD content file) before
# reinstalling this crontab, or the 01:00 job races an unsynced array. See docs/runbooks/.
0 1 * * 0 /willflix/bin/willflix-cron --timeout 50400 snapraid_weekly
0 1 * * 1-6 /willflix/bin/willflix-cron snapraid_daily

# Snapraid freshness monitor (independent of sync cron)
30 8 * * * /willflix/bin/willflix-cron check_snapraid_freshness

# ZFS snapshots — local instant-recovery layer (rpool/willflix + USERDATA; missing
# datasets skipped). See etc/zfs-snapshot.conf and docs/runbooks/zfs-datasets.md.
0 * * * * /willflix/bin/willflix-cron zfs-snapshot hourly 24
15 0 * * * /willflix/bin/willflix-cron zfs-snapshot daily 14

# MergerFS pool health check (every 15 min)
*/15 * * * * /willflix/bin/willflix-cron check_mergerfs_health

# Heartbeat — weekly channel test (Sun 9am), daily freshness + watchdog (Mon-Sat 9am)
0 9 * * 0 /willflix/bin/willflix-cron willflix-heartbeat --full
0 9 * * 1-6 /willflix/bin/willflix-cron willflix-heartbeat --silent

# Service health checks (every 15 min)
*/15 * * * * /willflix/bin/willflix-cron willflix-check-services

# Restart authentik containers stuck unhealthy after postgres restarts (every 5 min)
*/5 * * * * /willflix/bin/willflix-cron restart_unhealthy_authentik

# Backup freshness (daily after heartbeat)
15 9 * * * /willflix/bin/willflix-cron willflix-check-backups

# Media app health checks (every 6 hours)
0 */6 * * * /willflix/bin/willflix-cron check_media_apps

# Backups
30 2 * * * /willflix/bin/willflix-cron backup_postgres
30 3 * * * /willflix/bin/willflix-cron backup_restic

# Nightly container updates (after backups, skip Plex if streams active)
0 4 * * * /willflix/bin/willflix-cron update_containers
