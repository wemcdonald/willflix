MAILTO=will

# Snapraid - daily sync (Mon-Sat 1am), weekly sync+scrub (Sun 1am)
0 1 * * 0 /willflix/bin/cron/snapraid_weekly
0 1 * * 1-6 /willflix/bin/cron/snapraid_daily

# Snapraid freshness monitor (independent of sync cron)
30 8 * * * /willflix/bin/cron/check_snapraid_freshness

# MergerFS pool health check (every 15 min)
*/15 * * * * /willflix/bin/cron/check_mergerfs_health

# Heartbeat — weekly channel test (Sun 9am), daily freshness + watchdog (Mon-Sat 9am)
0 9 * * 0 /willflix/bin/cron/willflix-heartbeat --full
0 9 * * 1-6 /willflix/bin/cron/willflix-heartbeat --silent

# Service health checks (every 15 min)
*/15 * * * * /willflix/bin/cron/willflix-check-docker
*/15 * * * * /willflix/bin/cron/willflix-check-systemd

# Backup freshness (daily after heartbeat)
15 9 * * * /willflix/bin/cron/willflix-check-backups

# Media app health checks (every 6 hours)
0 */6 * * * /willflix/bin/cron/check_media_apps

# Backups
0 0 * * * /usr/local/bin/cronic /willflix/bin/cron/backup_plex
30 2 * * * /willflix/bin/cron/backup_postgres
30 3 * * * /willflix/bin/cron/backup_restic
