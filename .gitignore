# Application data (container volumes, databases, indexes — see docker/appdata/.gitignore)
docker/appdata/*
!docker/appdata/.gitignore
!docker/appdata/nzbget/
docker/logs/

# Compat symlinks (filesystem glue for old /docker/config paths)
docker/config/
docker/docker-compose.yml
docker/secrets

# Build artifacts
*.log
*.tmp
*.swp
*~
*.pyc
__pycache__/

# Dependencies
node_modules/
.venv/

# MemPalace vector DB (large binaries — not git-friendly; back up separately)
mempalace/

# OS files
.DS_Store
Thumbs.db
