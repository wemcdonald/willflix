#!/bin/bash
# rebuild-lafayette — guided rebuild of lafayette server from a fresh Ubuntu 22.04 install.
#
# Prerequisites:
#   - Fresh Ubuntu 22.04 install with 'will' user and sudo access
#   - Network access to GitHub
#   - SSH key for GitHub (or HTTPS token)
#   - git-crypt symmetric key file (from LastPass)
#
# Usage:
#   curl/scp this script to the new machine, then:
#   chmod +x rebuild-lafayette && sudo ./rebuild-lafayette
#
# Each stage pauses for confirmation. Answer 'n' to skip a stage.
#
# ─────────────────────────────────────────────────────────────────────────────
# RULES FOR AI AGENTS EDITING THIS SCRIPT  (read before changing anything)
#
#  1. Idempotent & re-runnable. Every stage must be safe to run repeatedly and
#     guarded so it skips work already done. Never assume a pristine machine.
#  2. Stages stay individually confirmable (confirm || return 0). Never collapse
#     stages or drop the prompts — partial rebuilds depend on skipping stages.
#  3. Runs as root (check_root). Anything created for 'will' must be chown'd will.
#  4. NEVER mkdir /Volumes/Media* (or any /Volumes/* data path) on the root SSD.
#     Those are mountpoints for the spinning drives; creating them empty makes
#     Docker/services write to the root disk and shadows the real mounts when the
#     drives come up. Create the bare mountpoint only in Stage 5, only to mount it.
#  5. Build-context dirs (compose `context:`) hold SOURCE that lives in backups
#     (appdata via restic/B2, ~/code via the home backup). They CANNOT be created
#     with mkdir — an empty dir has no Dockerfile. Detect & report; never fake them.
#  6. Secrets come from git-crypt (Stage 4). Never hardcode a credential here —
#     read from "$REPO_DIR/secrets/*", and assume the repo may still be locked.
#  7. Private images need `docker login ghcr.io` BEFORE `compose up`, or a single
#     unauthorized pull aborts the whole batch (see Stage 7).
#  8. snapraid crons are ENABLED in etc/root-crontab (re-enabled 2026-06-21 on new
#     hardware; old PSU/hang cause gone). GATE: run one baseline `snapraid sync`
#     after the drives mount before relying on the 01:00 job.
#  9. `set -euo pipefail` is on: guard greps with `|| true` (no match returns 1),
#     guard empty-array expansion, and wrap long-running ops in `timeout`.
# 10. Reference drives by LABEL= (fstab) / by-id ata-* (smartd) — never /dev/sdX.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

REPO_URL="git@github.com:wemcdonald/willflix.git"
REPO_DIR="/willflix"
COMPOSE_PROJECT="config"

# --- Helpers ---

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

info()  { echo -e "${GREEN}[✓]${NC} $*"; }
warn()  { echo -e "${YELLOW}[!]${NC} $*"; }
err()   { echo -e "${RED}[✗]${NC} $*"; }
stage() { echo -e "\n${GREEN}═══════════════════════════════════════${NC}"; echo -e "${GREEN}  Stage $1: $2${NC}"; echo -e "${GREEN}═══════════════════════════════════════${NC}\n"; }

confirm() {
    local prompt="${1:-Proceed?}"
    read -rp "$prompt [Y/n] " reply
    [[ -z "$reply" || "$reply" =~ ^[Yy] ]]
}

check_root() {
    if [[ $EUID -ne 0 ]]; then
        err "This script must be run as root (sudo ./rebuild-lafayette)"
        exit 1
    fi
}

# --- Stage 1: Prerequisites ---

stage_1_prerequisites() {
    stage 1 "Prerequisites"

    # Check Ubuntu version
    if grep -q 'VERSION_ID="22.04"' /etc/os-release; then
        info "Ubuntu 22.04 detected"
    else
        warn "Expected Ubuntu 22.04, found: $(grep VERSION_ID /etc/os-release)"
        confirm "Continue anyway?" || exit 1
    fi

    # Check internet
    if ping -c1 -W3 github.com &>/dev/null; then
        info "Internet connectivity OK"
    else
        err "Cannot reach github.com — check network"
        exit 1
    fi

    # Check sudo
    info "Running as root"

    # Check for will user
    if id will &>/dev/null; then
        info "User 'will' exists"
    else
        warn "User 'will' does not exist — creating"
        adduser --gecos "" will
        usermod -aG sudo will
        info "Created user 'will' with sudo"
    fi
}

# --- Stage 2: Packages ---

stage_2_packages() {
    stage 2 "Packages"

    echo "Will install: docker-ce, git-crypt, smartmontools, mergerfs, snapraid,"
    echo "              jq, htop, tmux, ripgrep, mosh, and other utilities."
    echo ""
    confirm || return 0

    apt-get update

    # Docker (official repo)
    if ! command -v docker &>/dev/null; then
        info "Installing Docker..."
        apt-get install -y ca-certificates curl gnupg
        install -m 0755 -d /etc/apt/keyrings
        curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
        chmod a+r /etc/apt/keyrings/docker.gpg
        echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" > /etc/apt/sources.list.d/docker.list
        apt-get update
        apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
        usermod -aG docker will
        info "Docker installed"
    else
        info "Docker already installed"
    fi

    # Core packages
    PACKAGES=(
        git git-crypt smartmontools mergerfs snapraid
        jq htop tmux ripgrep mosh curl wget
        python3 python3-yaml restic ethtool
    )
    apt-get install -y "${PACKAGES[@]}"
    info "Core packages installed"

    # Tailscale — host-level mesh VPN (NOT a Docker service; was manually installed
    # on the old box). The sysctl.d/99-tailscale.conf forwarding drop-in ships in
    # Stage 6. Auth is interactive, so `tailscale up` is left for the operator.
    if ! command -v tailscale &>/dev/null; then
        info "Installing Tailscale..."
        curl -fsSL https://tailscale.com/install.sh | sh
        warn "Run 'sudo tailscale up' manually to authenticate (interactive browser login)."
        warn "If this host was an exit node/subnet router, add --advertise-exit-node / --advertise-routes."
    else
        info "Tailscale already installed"
    fi
}

# --- Stage 3: Clone repo ---

stage_3_clone() {
    stage 3 "Clone repo"

    # If root is ZFS, put /willflix on its own dataset before cloning so appdata +
    # configs snapshot/roll back independently of the OS (docs/runbooks/zfs-datasets.md).
    if command -v zfs &>/dev/null && zpool list -H -o name 2>/dev/null | grep -qx rpool \
            && ! zfs list -H -o name rpool/willflix &>/dev/null \
            && [[ ! -d "$REPO_DIR/.git" ]]; then
        if confirm "Create ZFS dataset rpool/willflix mounted at $REPO_DIR?"; then
            zfs create -o mountpoint="$REPO_DIR" -o compression=zstd -o atime=off -o xattr=sa rpool/willflix
            chown will:will "$REPO_DIR"
            info "created rpool/willflix"
        fi
    fi

    if [[ -d "$REPO_DIR/.git" ]]; then
        info "$REPO_DIR already exists — skipping clone"
        read -rp "Pull latest from origin? (leave existing checkout if you have local changes) [y/N] " reply
        if [[ "$reply" =~ ^[Yy] ]]; then
            git -C "$REPO_DIR" pull
        else
            info "Leaving existing checkout as-is"
        fi
    else
        echo "Will clone $REPO_URL to $REPO_DIR"
        echo ""
        echo "Make sure the SSH key for GitHub is available."
        echo "If using will's SSH key, it should be at ~will/.ssh/id_ed25519"
        echo "(You can paste it from LastPass now if needed)"
        echo ""
        confirm || return 0

        git clone "$REPO_URL" "$REPO_DIR"
        chown -R will:will "$REPO_DIR"
        info "Repo cloned to $REPO_DIR"
    fi

    # Convenience symlinks
    ln -sfn "$REPO_DIR" /home/will/willflix 2>/dev/null || true
    ln -sfn "$REPO_DIR/bin/cron" /home/will/bin/cron 2>/dev/null || { mkdir -p /home/will/bin && ln -sfn "$REPO_DIR/bin/cron" /home/will/bin/cron; }
    info "Convenience symlinks created"
}

# --- Stage 4: Unlock secrets ---

stage_4_secrets() {
    stage 4 "Unlock secrets"

    if file "$REPO_DIR/secrets/smtp_password" 2>/dev/null | grep -q 'ASCII'; then
        info "Secrets already decrypted"
        return 0
    fi

    echo "Need the git-crypt symmetric key to decrypt secrets."
    echo ""
    echo "To retrieve from LastPass:"
    echo "  1. Find secure note 'lafayette git-crypt key'"
    echo "  2. Copy the base64 content"
    echo "  3. Decode: echo '<base64>' | base64 -d > /tmp/git-crypt-key"
    echo ""
    read -rp "Path to git-crypt key file [/tmp/git-crypt-key]: " keyfile
    keyfile="${keyfile:-/tmp/git-crypt-key}"

    if [[ ! -f "$keyfile" ]]; then
        err "Key file not found: $keyfile"
        return 1
    fi

    git -C "$REPO_DIR" crypt unlock "$keyfile"
    info "Secrets decrypted"

    echo ""
    warn "Remember to delete the key file: rm $keyfile"
}

# --- Stage 5: Mount drives ---

stage_5_mounts() {
    stage 5 "Mount drives"

    echo "Expected drives from etc/fstab:"
    echo ""

    # Show expected vs detected
    local expected_labels
    expected_labels=$(grep '^LABEL=' "$REPO_DIR/etc/fstab" | awk '{print $1}' | sed 's/LABEL=//')

    local missing=0
    for label in $expected_labels; do
        device=$(blkid -L "$label" 2>/dev/null || true)
        if [[ -n "$device" ]]; then
            info "$label → $device"
        else
            warn "$label → NOT FOUND"
            missing=$((missing + 1))
        fi
    done

    if [[ $missing -gt 0 ]]; then
        echo ""
        warn "$missing drive(s) not found. This is expected if rebuilding during a drive failure."
    fi

    echo ""
    echo "Will add fstab entries and mount available drives."
    confirm || return 0

    # Create mount points
    for label in $expected_labels; do
        mount_point=$(grep "LABEL=$label" "$REPO_DIR/etc/fstab" | awk '{print $2}')
        mkdir -p "$mount_point"
    done
    mkdir -p /Volumes/Media
    mkdir -p /snapraid

    # Add fstab entries (skip if already present)
    while IFS= read -r line; do
        [[ "$line" =~ ^# ]] && continue
        [[ -z "$line" ]] && continue
        # Extract the mount point to check for duplicates
        mp=$(echo "$line" | awk '{print $2}')
        if ! grep -q "$mp" /etc/fstab 2>/dev/null; then
            echo "$line" >> /etc/fstab
        fi
    done < <(grep -E '^LABEL=Media|^/Volumes/Media\[|^LABEL=Bonus' "$REPO_DIR/etc/fstab")

    mount -a 2>/dev/null || true
    info "Drives mounted (check output above for errors)"

    # Show what's mounted
    echo ""
    df -h /Volumes/Media* /Volumes/Bonus* 2>/dev/null | head -20 || true
}

# --- Stage 6: System configs ---

stage_6_configs() {
    stage 6 "System configs"

    echo "Will install:"
    echo "  - smartd.conf → /etc/smartd.conf"
    echo "  - snapraid.conf → /etc/snapraid.conf"
    echo "  - Root crontab from etc/root-crontab"
    echo "  - Systemd units (symlinked from etc/systemd/)"
    echo "  - Systemd manager drop-ins (copied from etc/systemd.conf.d/)"
    echo "  - Sendmail wrapper (symlinked from bin/sendmail-system)"
    echo ""
    confirm || return 0

    # smartd
    cp "$REPO_DIR/etc/smartd.conf" /etc/smartd.conf
    systemctl restart smartd 2>/dev/null || true
    info "smartd.conf installed"

    # snapraid
    cp "$REPO_DIR/etc/snapraid.conf" /etc/snapraid.conf
    info "snapraid.conf installed"

    # Crontab
    crontab "$REPO_DIR/etc/root-crontab"
    info "Root crontab installed"

    # sysctl.d drop-ins
    if [[ -d "$REPO_DIR/etc/sysctl.d" ]]; then
        for conf in "$REPO_DIR/etc/sysctl.d/"*.conf; do
            [[ -f "$conf" ]] || continue
            ln -sfn "$conf" "/etc/sysctl.d/$(basename "$conf")"
        done
        sysctl --system &>/dev/null
        info "sysctl.d drop-ins symlinked and loaded"
    fi

    # modules-load.d drop-ins
    if [[ -d "$REPO_DIR/etc/modules-load.d" ]]; then
        for conf in "$REPO_DIR/etc/modules-load.d/"*.conf; do
            [[ -f "$conf" ]] || continue
            ln -sfn "$conf" "/etc/modules-load.d/$(basename "$conf")"
            while read -r mod; do
                [[ -z "$mod" || "$mod" == \#* ]] && continue
                modprobe "$mod" 2>/dev/null || true
            done < "$conf"
        done
        info "modules-load.d drop-ins symlinked and loaded"
    fi

    # udev rules
    if [[ -d "$REPO_DIR/etc/udev/rules.d" ]]; then
        for rule in "$REPO_DIR/etc/udev/rules.d/"*.rules; do
            [[ -f "$rule" ]] || continue
            ln -sfn "$rule" "/etc/udev/rules.d/$(basename "$rule")"
        done
        udevadm control --reload &>/dev/null
        udevadm trigger --subsystem-match=watchdog --action=change &>/dev/null || true
        info "udev rules symlinked and reloaded"
    fi

    # Systemd units
    local count=0
    for unit in "$REPO_DIR/etc/systemd/"*.service; do
        name=$(basename "$unit")
        ln -sfn "$unit" "/etc/systemd/system/$name"
        count=$((count + 1))
    done
    info "$count systemd units symlinked"

    # Systemd manager drop-ins (system.conf.d)
    if [[ -d "$REPO_DIR/etc/systemd.conf.d" ]]; then
        mkdir -p /etc/systemd/system.conf.d
        for conf in "$REPO_DIR/etc/systemd.conf.d/"*.conf; do
            [[ -f "$conf" ]] || continue
            ln -sfn "$conf" "/etc/systemd/system.conf.d/$(basename "$conf")"
        done
        info "systemd manager drop-ins symlinked"
    fi
    systemctl daemon-reload
    info "systemd daemon reloaded"

    # Enable non-Docker helper units (the docker *.service wrappers are run by compose,
    # not systemd; this oneshot applies Tailscale exit-node throughput tuning at boot).
    systemctl enable --now tailscale-udp-gro.service 2>/dev/null \
        && info "tailscale-udp-gro.service enabled" \
        || warn "tailscale-udp-gro.service not enabled (check ethtool / unit)"

    # Sendmail wrapper
    ln -sfn "$REPO_DIR/bin/sendmail-system" /usr/sbin/sendmail
    info "sendmail → $REPO_DIR/bin/sendmail-system"

    # Docker compat symlink
    ln -sfn "$REPO_DIR/docker" /docker
    info "/docker → $REPO_DIR/docker"

    # Compose compat (config/ dir with symlinks)
    mkdir -p "$REPO_DIR/willflix/docker"
    ln -sfn "$REPO_DIR/docker/compose.yml" "$REPO_DIR/willflix/docker/docker-compose.yml"
    ln -sfn "$REPO_DIR/secrets" "$REPO_DIR/willflix/docker/secrets"
    info "Docker compat symlinks created"

    # Monitor dirs
    install -d -m 1777 /var/tmp/willflix-monitors
    install -d -m 1777 /var/tmp/willflix-notify
    info "Monitor/dedup directories created"
}

# --- Stage 7: Docker services ---

stage_7_docker() {
    stage 7 "Docker services"

    echo "Will start all Docker services via compose."
    echo "This may take a while for image pulls on a fresh install."
    echo ""
    confirm || return 0

    cd "$REPO_DIR/docker"
    local compose="$REPO_DIR/docker/compose.yml"

    # Collect build-context dirs (compose `context:`) — these need restored SOURCE,
    # so we exclude them from mkdir and report any that are missing (rule #4/#5).
    local contexts=()
    mapfile -t contexts < <(grep -E '^[[:space:]]*context:' "$compose" 2>/dev/null \
        | sed -E 's/.*context:[[:space:]]*//' | tr -d '"' || true)

    # Create the host bind-mount data dirs that are safe to create empty:
    # appdata/* + docker/logs. We deliberately skip /Volumes/* (drive mounts) and
    # any path that is a build context.
    mkdir -p "$REPO_DIR/docker/logs"
    while read -r d; do
        [[ -z "$d" ]] && continue
        local is_ctx=0
        for c in "${contexts[@]:-}"; do [[ "$c" == "$d" ]] && is_ctx=1; done
        (( is_ctx )) && continue
        mkdir -p "$d"
    done < <(grep -oE '/willflix/docker/appdata/[A-Za-z0-9_-]+' "$compose" 2>/dev/null | sort -u || true)
    info "appdata data dirs ensured (build-context + /Volumes paths skipped)"

    # Report missing build contexts — these block `compose up` until restored.
    local missing=()
    for c in "${contexts[@]:-}"; do
        [[ -z "$c" ]] && continue
        [[ -e "$c" ]] || missing+=("$c")
    done
    if (( ${#missing[@]} )); then
        warn "Missing build-context dirs — these block 'compose up' until their SOURCE is restored:"
        printf '      %s\n' "${missing[@]}"
        echo ""
        echo "  Restore first, then re-run this stage:"
        echo "    • appdata builds (gastown/guildmaster/health-server): restic restore from B2"
        echo "    • ~/code builds (homebot/parchment-server): restore /home/will from the home backup"
        echo "  See docs/runbooks for the exact restic commands."
        echo ""
        warn "A full 'compose up' WILL abort on these. Only override if you know what you're doing."
        confirm "Try 'compose up' anyway (expected to fail on the missing builds)?" || return 0
    fi

    # Authenticate to GHCR for private images (e.g. ghcr.io/wemcdonald/healthbot).
    # Without this, the unauthorized pull aborts the whole `compose up` batch.
    if [[ -s "$REPO_DIR/secrets/healthbot_build_token" ]]; then
        if docker login ghcr.io -u wemcdonald --password-stdin \
                < "$REPO_DIR/secrets/healthbot_build_token" &>/dev/null; then
            info "Logged in to ghcr.io (private images)"
        else
            warn "ghcr.io login failed — private images (healthbot) may not pull"
        fi
    else
        warn "secrets/healthbot_build_token missing — is the repo git-crypt unlocked?"
    fi

    # Compose's default network is external (config_default). Its gateway 172.30.0.1
    # is how containers (traefik) reach the host opencode service, so the subnet is
    # fixed — a generic `network create` would assign the wrong gateway.
    docker network inspect config_default &>/dev/null || \
        docker network create --subnet 172.30.0.0/16 --gateway 172.30.0.1 config_default
    info "config_default network present"

    docker compose -p "$COMPOSE_PROJECT" up -d
    info "Docker services started"

    echo ""
    echo "Container status:"
    docker ps --format 'table {{.Names}}\t{{.Status}}' | head -45
}

# --- Stage 8: Restore postgres ---

stage_8_postgres() {
    stage 8 "Restore PostgreSQL"

    local dump_dir="/Volumes/Bonus1/postgres-backup"
    local latest_dir="$dump_dir/latest"

    if [[ ! -d "$dump_dir" ]]; then
        warn "Dump directory not found: $dump_dir"
        echo "If Bonus1 is not mounted, you can restore from restic later."
        echo "See docs/disaster-recovery.md for instructions."
        return 0
    fi

    if [[ ! -L "$latest_dir" && ! -d "$latest_dir" ]]; then
        warn "No 'latest' symlink found in $dump_dir"
        echo "Available date directories:"
        ls -d "$dump_dir"/20* 2>/dev/null || echo "  (none)"
        return 0
    fi

    echo "Latest dumps ($(readlink "$latest_dir" 2>/dev/null || basename "$latest_dir")):"
    ls -lh "$latest_dir"/*.sql.gz 2>/dev/null
    echo ""

    confirm "Restore these dumps?" || return 0

    # Wait for postgres to be ready
    echo "Waiting for postgres to be ready..."
    local tries=0
    while ! docker exec config-postgres-1 pg_isready -U will &>/dev/null; do
        tries=$((tries + 1))
        if [[ $tries -gt 30 ]]; then
            err "Postgres not ready after 30 seconds"
            return 1
        fi
        sleep 1
    done
    info "Postgres is ready"

    # Restore globals first
    if [[ -f "$latest_dir/globals.sql.gz" ]]; then
        gunzip -c "$latest_dir/globals.sql.gz" | docker exec -i config-postgres-1 psql -U will postgres 2>&1 | tail -3
        info "Globals restored"
    fi

    # Restore each database
    for dump in "$latest_dir"/*.sql.gz; do
        local dbname
        dbname=$(basename "$dump" .sql.gz)
        [[ "$dbname" == "globals" ]] && continue

        echo "Restoring $dbname..."
        docker exec config-postgres-1 psql -U will -tc "SELECT 1 FROM pg_database WHERE datname='$dbname'" | grep -q 1 || \
            docker exec config-postgres-1 createdb -U will "$dbname" 2>/dev/null || true
        gunzip -c "$dump" | docker exec -i config-postgres-1 psql -U will "$dbname" 2>&1 | tail -3
        info "$dbname restored"
    done
}

# --- Stage 9: Verify ---

stage_9_verify() {
    stage 9 "Verify"

    local issues=0

    echo "Checking system health..."
    echo ""

    # Drives
    if mountpoint -q /Volumes/Media 2>/dev/null; then
        info "MergerFS pool mounted"
    else
        err "MergerFS pool NOT mounted"
        issues=$((issues + 1))
    fi

    # Docker
    local running
    running=$(docker ps -q | wc -l)
    if [[ $running -gt 30 ]]; then
        info "$running Docker containers running"
    else
        warn "Only $running Docker containers running (expected ~38)"
        issues=$((issues + 1))
    fi

    # Unhealthy containers
    local unhealthy
    unhealthy=$(docker ps --filter health=unhealthy --format '{{.Names}}' 2>/dev/null)
    if [[ -z "$unhealthy" ]]; then
        info "No unhealthy containers"
    else
        warn "Unhealthy containers: $unhealthy"
        issues=$((issues + 1))
    fi

    # Secrets decrypted
    if file "$REPO_DIR/secrets/smtp_password" 2>/dev/null | grep -q 'ASCII'; then
        info "Secrets are decrypted"
    else
        err "Secrets are NOT decrypted"
        issues=$((issues + 1))
    fi

    # Crontab
    if crontab -l 2>/dev/null | grep -q willflix; then
        info "Root crontab installed"
    else
        err "Root crontab not installed"
        issues=$((issues + 1))
    fi

    # Backups directory
    if [[ -d /Volumes/Bonus1/postgres-backup ]]; then
        info "Postgres backup directory exists"
    else
        warn "Postgres backup directory not found"
        issues=$((issues + 1))
    fi

    # Alerting test
    echo ""
    if confirm "Send a test notification to verify alerting?"; then
        "$REPO_DIR/bin/willflix-notify" --test --subject "lafayette rebuild complete" && \
            info "Test notification sent" || warn "Notification test failed"
    fi

    echo ""
    echo "═══════════════════════════════════════"
    if [[ $issues -eq 0 ]]; then
        info "All checks passed. Rebuild complete!"
    else
        warn "$issues issue(s) found. Review the warnings above."
    fi
    echo "═══════════════════════════════════════"
}

# --- Main ---

main() {
    echo ""
    echo "╔═══════════════════════════════════════╗"
    echo "║     lafayette server rebuild script    ║"
    echo "╠═══════════════════════════════════════╣"
    echo "║  Guides you through rebuilding from a  ║"
    echo "║  fresh Ubuntu 22.04 install.           ║"
    echo "║                                        ║"
    echo "║  You'll need:                          ║"
    echo "║  • SSH key for GitHub                  ║"
    echo "║  • git-crypt key (from LastPass)       ║"
    echo "║  • Network access                      ║"
    echo "╚═══════════════════════════════════════╝"
    echo ""

    check_root

    stage_1_prerequisites
    stage_2_packages
    stage_3_clone
    stage_4_secrets
    stage_5_mounts
    stage_6_configs
    stage_7_docker
    stage_8_postgres
    stage_9_verify
}

main "$@"
