#!/bin/bash

# Sync Users from Authentik to Calibre-Web
# Usage: ./sync-users [username|email]
# If no argument provided, syncs all users in Willflix group
# If username or email provided, syncs only that specific user

set -e

# Load configuration
# Check if running in webhook container
if [ -f "/app/secrets/authentik_api_env" ]; then
    source /app/secrets/authentik_api_env
else
    source /willflix/docker/secrets/authentik_api_env
fi

# Check required environment variables
if [ -z "$AUTHENTIK_API_KEY" ] || [ -z "$AUTHENTIK_WILLFLIX_GROUP_ID" ]; then
    echo -e "\033[0;31m[ERROR]\033[0m Missing required environment variables:"
    [ -z "$AUTHENTIK_API_KEY" ] && echo "  - AUTHENTIK_API_KEY not set"
    [ -z "$AUTHENTIK_WILLFLIX_GROUP_ID" ] && echo "  - AUTHENTIK_WILLFLIX_GROUP_ID not set"
    echo "Please check /willflix/docker/secrets/authentik_api_env"
    exit 1
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if add-calibre-user script exists
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ADD_CALIBRE_SCRIPT="$SCRIPT_DIR/add-calibre-user"

if [ ! -f "$ADD_CALIBRE_SCRIPT" ]; then
    print_error "add-calibre-user script not found at $ADD_CALIBRE_SCRIPT"
    exit 1
fi

# Check if specific user requested
SYNC_TARGET="$1"

if [ -n "$SYNC_TARGET" ]; then
    print_status "Starting single user sync: $SYNC_TARGET"
else
    print_status "Starting user sync from Authentik to Calibre-Web"
fi

# Initialize counters
TOTAL_USERS=0
SYNCED_USERS=0
SKIPPED_USERS=0
ERROR_USERS=0

# Function to sync a single user
sync_single_user() {
    local user_data="$1"
    local username=$(echo "$user_data" | jq -r '.username')
    local email=$(echo "$user_data" | jq -r '.email')
    local user_type=$(echo "$user_data" | jq -r '.type')
    
    TOTAL_USERS=$((TOTAL_USERS + 1))
    
    # Skip service accounts
    if [ "$user_type" = "internal_service_account" ]; then
        print_warning "Skipping service account: $username"
        SKIPPED_USERS=$((SKIPPED_USERS + 1))
        return
    fi
    
    # Skip users without email
    if [ "$email" = "null" ] || [ -z "$email" ]; then
        print_warning "Skipping user without email: $username"
        SKIPPED_USERS=$((SKIPPED_USERS + 1))
        return
    fi
    
    print_status "Syncing user: $username ($email)"
    
    # Call add-calibre-user script
    if "$ADD_CALIBRE_SCRIPT" "$username" "$email" "user" > /dev/null 2>&1; then
        print_status "✓ Successfully synced to Calibre-Web: $username"
        
        # Add user to Nextcloud
        print_status "Adding $username to Nextcloud..."
        if "$SCRIPT_DIR/add-nextcloud-user" "$username" "$email" > /dev/null 2>&1; then
            print_status "✓ Successfully synced to Nextcloud: $username"
        else
            print_warning "✗ Failed to sync to Nextcloud: $username"
        fi
        
        SYNCED_USERS=$((SYNCED_USERS + 1))
        
        # Invite user to Plex
        print_status "Inviting $username to Plex..."
        if "$SCRIPT_DIR/invite-to-plex" "$email" > /dev/null 2>&1; then
            print_status "✓ Plex invitation sent to: $email"
        else
            print_warning "✗ Failed to invite to Plex: $email"
        fi
    else
        print_error "✗ Failed to sync: $username"
        ERROR_USERS=$((ERROR_USERS + 1))
    fi
}

# Function to sync a specific user by username or email
sync_specific_user() {
    local target="$1"
    
    # Try to find user by username first, then email
    print_status "Searching for user: $target"
    
    # Search by username
    local api_url="https://auth.willflix.org/api/v3/core/users/?groups=${AUTHENTIK_WILLFLIX_GROUP_ID}&search=${target}"
    local response=$(curl -s -H "Authorization: Bearer $AUTHENTIK_API_KEY" "$api_url")
    
    if [ $? -ne 0 ]; then
        print_error "Failed to fetch user from Authentik API"
        return 1
    fi
    
    # Check if response contains error
    if echo "$response" | jq -e '.detail' > /dev/null 2>&1; then
        local error_msg=$(echo "$response" | jq -r '.detail')
        print_error "API Error: $error_msg"
        return 1
    fi
    
    # Check if any users found
    local user_count=$(echo "$response" | jq -r '.count')
    if [ "$user_count" -eq 0 ]; then
        print_error "User not found: $target"
        return 1
    fi
    
    # Find exact match by username or email
    local user_found=""
    echo "$response" | jq -c '.results[]' | while read -r user; do
        local username=$(echo "$user" | jq -r '.username')
        local email=$(echo "$user" | jq -r '.email')
        
        if [ "$username" = "$target" ] || [ "$email" = "$target" ]; then
            user_found="$user"
            break
        fi
    done
    
    if [ -z "$user_found" ]; then
        # If no exact match, try first result
        user_found=$(echo "$response" | jq -c '.results[0]')
    fi
    
    if [ -n "$user_found" ]; then
        sync_single_user "$user_found"
    else
        print_error "No matching user found for: $target"
        return 1
    fi
}

# Function to sync a single page of users (for full sync)
sync_users_page() {
    local page=$1
    local api_url="https://auth.willflix.org/api/v3/core/users/?groups=${AUTHENTIK_WILLFLIX_GROUP_ID}&page=${page}&page_size=50"
    
    print_status "Fetching users from Authentik (page $page)..."
    
    # Fetch users from Authentik API
    local response=$(curl -s -H "Authorization: Bearer $AUTHENTIK_API_KEY" "$api_url")
    
    if [ $? -ne 0 ]; then
        print_error "Failed to fetch users from Authentik API"
        return 1
    fi
    
    # Check if response contains error
    if echo "$response" | jq -e '.detail' > /dev/null 2>&1; then
        local error_msg=$(echo "$response" | jq -r '.detail')
        print_error "API Error: $error_msg"
        return 1
    fi
    
    # Extract users from response
    local users=$(echo "$response" | jq -r '.results[]')
    
    if [ -z "$users" ]; then
        print_warning "No users found on page $page"
        return 0
    fi
    
    # Process each user
    echo "$response" | jq -c '.results[]' | while read -r user; do
        sync_single_user "$user"
    done
    
    # Check if there are more pages
    local next_page=$(echo "$response" | jq -r '.next')
    if [ "$next_page" != "null" ] && [ -n "$next_page" ]; then
        return 2  # More pages available
    else
        return 0  # No more pages
    fi
}

# Main execution logic
if [ -n "$SYNC_TARGET" ]; then
    # Sync specific user
    sync_specific_user "$SYNC_TARGET"
    result=$?
    
    if [ $result -ne 0 ]; then
        print_error "Failed to sync user: $SYNC_TARGET"
        exit 1
    fi
else
    # Sync all users (existing behavior)
    page=1
    while true; do
        sync_users_page $page
        result=$?
        
        if [ $result -eq 1 ]; then
            print_error "Sync failed"
            exit 1
        elif [ $result -eq 2 ]; then
            page=$((page + 1))
            continue
        else
            break
        fi
    done
fi

print_status ""
print_status "Sync completed!"
print_status "Total users processed: $TOTAL_USERS"
print_status "Successfully synced: $SYNCED_USERS"
print_status "Skipped: $SKIPPED_USERS"
print_status "Errors: $ERROR_USERS"

if [ $ERROR_USERS -gt 0 ]; then
    exit 1
fi