#!/bin/bash

# Sync Users from Authentik to Calibre-Web
# Usage: ./sync-users

set -e

# Load configuration
source /docker/config/secrets/authentik_api_env

# Check required environment variables
if [ -z "$AUTHENTIK_API_KEY" ] || [ -z "$AUTHENTIK_WILLFLIX_GROUP_ID" ]; then
    echo -e "\033[0;31m[ERROR]\033[0m Missing required environment variables:"
    [ -z "$AUTHENTIK_API_KEY" ] && echo "  - AUTHENTIK_API_KEY not set"
    [ -z "$AUTHENTIK_WILLFLIX_GROUP_ID" ] && echo "  - AUTHENTIK_WILLFLIX_GROUP_ID not set"
    echo "Please check /docker/config/secrets/authentik_api_env"
    exit 1
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if add-calibre-user script exists
if [ ! -f "/docker/bin/add-calibre-user" ]; then
    print_error "add-calibre-user script not found at /docker/bin/add-calibre-user"
    exit 1
fi

print_status "Starting user sync from Authentik to Calibre-Web"

# Initialize counters
TOTAL_USERS=0
SYNCED_USERS=0
SKIPPED_USERS=0
ERROR_USERS=0

# Function to sync a single page of users
sync_users_page() {
    local page=$1
    local api_url="https://auth.willflix.org/api/v3/core/users/?groups=${AUTHENTIK_WILLFLIX_GROUP_ID}&page=${page}&page_size=50"
    
    print_status "Fetching users from Authentik (page $page)..."
    
    # Fetch users from Authentik API
    local response=$(curl -s -H "Authorization: Bearer $AUTHENTIK_API_KEY" "$api_url")
    
    if [ $? -ne 0 ]; then
        print_error "Failed to fetch users from Authentik API"
        return 1
    fi
    
    # Check if response contains error
    if echo "$response" | jq -e '.detail' > /dev/null 2>&1; then
        local error_msg=$(echo "$response" | jq -r '.detail')
        print_error "API Error: $error_msg"
        return 1
    fi
    
    # Extract users from response
    local users=$(echo "$response" | jq -r '.results[]')
    
    if [ -z "$users" ]; then
        print_warning "No users found on page $page"
        return 0
    fi
    
    # Process each user
    echo "$response" | jq -c '.results[]' | while read -r user; do
        local username=$(echo "$user" | jq -r '.username')
        local email=$(echo "$user" | jq -r '.email')
        local user_type=$(echo "$user" | jq -r '.type')
        
        TOTAL_USERS=$((TOTAL_USERS + 1))
        
        # Skip service accounts
        if [ "$user_type" = "internal_service_account" ]; then
            print_warning "Skipping service account: $username"
            SKIPPED_USERS=$((SKIPPED_USERS + 1))
            continue
        fi
        
        # Skip users without email
        if [ "$email" = "null" ] || [ -z "$email" ]; then
            print_warning "Skipping user without email: $username"
            SKIPPED_USERS=$((SKIPPED_USERS + 1))
            continue
        fi
        
        print_status "Syncing user: $username ($email)"
        
        # Call add-calibre-user script
        if /docker/bin/add-calibre-user "$username" "$email" "user" > /dev/null 2>&1; then
            print_status "✓ Successfully synced: $username"
            SYNCED_USERS=$((SYNCED_USERS + 1))
        else
            print_error "✗ Failed to sync: $username"
            ERROR_USERS=$((ERROR_USERS + 1))
        fi
    done
    
    # Check if there are more pages
    local next_page=$(echo "$response" | jq -r '.next')
    if [ "$next_page" != "null" ] && [ -n "$next_page" ]; then
        return 2  # More pages available
    else
        return 0  # No more pages
    fi
}

# Main sync loop
page=1
while true; do
    sync_users_page $page
    result=$?
    
    if [ $result -eq 1 ]; then
        print_error "Sync failed"
        exit 1
    elif [ $result -eq 2 ]; then
        page=$((page + 1))
        continue
    else
        break
    fi
done

print_status ""
print_status "Sync completed!"
print_status "Total users processed: $TOTAL_USERS"
print_status "Successfully synced: $SYNCED_USERS"
print_status "Skipped: $SKIPPED_USERS"
print_status "Errors: $ERROR_USERS"

if [ $ERROR_USERS -gt 0 ]; then
    exit 1
fi