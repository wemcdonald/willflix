#!/bin/bash
# backup_postgres — daily per-database pg_dump with auto-discovery.
# Dumps each database individually for easy single-DB restore.
# Also dumps global roles/permissions.
#
# Layout:
#   /Volumes/Bonus1/postgres-backup/
#   ├── 2026-03-05/
#   │   ├── globals.sql.gz
#   │   ├── authentik.sql.gz
#   │   └── ...
#   ├── latest → 2026-03-05
#   └── (14 days of dated dirs)
#
# Run daily at 2:30am via cron.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NOTIFY="$(cd "$SCRIPT_DIR/.." && pwd)/willflix-notify"
MONITOR_STAMP="/var/tmp/willflix-monitors/backup_postgres"

CONTAINER="config-postgres-1"
DB_USER="will"
BACKUP_DIR="/Volumes/Bonus1/postgres-backup"
RETENTION_DAYS=14
TODAY=$(date +%Y-%m-%d)
TODAY_DIR="${BACKUP_DIR}/${TODAY}"

# Ensure backup directory exists
if ! mountpoint -q /Volumes/Bonus1 2>/dev/null; then
    "$NOTIFY" --severity CRITICAL --key "backup-postgres-fail" \
        --subject "PostgreSQL backup failed on $(hostname)" \
        --body "/Volumes/Bonus1 is not mounted. Cannot write backups."
    exit 1
fi
mkdir -p "$TODAY_DIR"

FAILED=""

# Dump global roles and permissions
if docker exec "$CONTAINER" pg_dumpall -U "$DB_USER" --globals-only 2>/dev/null \
    | gzip > "${TODAY_DIR}/globals.sql.gz"; then
    :
else
    FAILED="${FAILED}  globals: pg_dumpall --globals-only failed\n"
fi

# Auto-discover databases (skip templates and system postgres db)
DBS=$(docker exec "$CONTAINER" psql -U "$DB_USER" -At -c \
    "SELECT datname FROM pg_database WHERE datistemplate = false AND datname != 'postgres'" 2>/dev/null) || {
    "$NOTIFY" --severity CRITICAL --key "backup-postgres-fail" \
        --subject "PostgreSQL backup failed on $(hostname)" \
        --body "Could not list databases from ${CONTAINER}.

Check:
  docker exec ${CONTAINER} psql -U ${DB_USER} -l
  docker logs ${CONTAINER} --tail 20"
    exit 1
}

# Dump each database
for db in $DBS; do
    if docker exec "$CONTAINER" pg_dump -U "$DB_USER" "$db" 2>/dev/null \
        | gzip > "${TODAY_DIR}/${db}.sql.gz"; then
        :
    else
        FAILED="${FAILED}  ${db}: pg_dump failed\n"
        rm -f "${TODAY_DIR}/${db}.sql.gz"
    fi
done

# Update latest symlink
ln -sfn "$TODAY" "${BACKUP_DIR}/latest"

# Alert on any failures
if [[ -n "$FAILED" ]]; then
    "$NOTIFY" --severity CRITICAL --key "backup-postgres-fail" \
        --subject "PostgreSQL backup had failures on $(hostname)" \
        --body "$(echo -e "Some databases failed to dump:\n\n${FAILED}\nSuccessful dumps are in ${TODAY_DIR}/\n\nCheck:\n  docker logs ${CONTAINER} --tail 20\n  ls -la ${TODAY_DIR}/")"
fi

# Clean up old date directories
find "$BACKUP_DIR" -maxdepth 1 -type d -name '20*' -mtime +"$RETENTION_DAYS" -exec rm -rf {} +

# Clean up old flat files from previous format (one-time migration)
find "$BACKUP_DIR" -maxdepth 1 -name '*.sql.gz' -delete 2>/dev/null || true

# Touch freshness stamp
install -d -m 1777 /var/tmp/willflix-monitors
touch "$MONITOR_STAMP"
