#!/bin/bash

for drive in /Volumes/Media?; do
  for media in TV Movies KidsTV KidsMovies Stand-Up Audiobooks Comics TV4K Movies4K 3DMovies; do
    path=$drive/$media

    if [[ -d "$path" ]]; then
  	  chown -R will:plex $path
  	  chmod -R uog+rX,ug+w $path
    fi
  done
done

# CalibreLibrary: calibre-web-automated's ingest service runs as root (s6 design),
# so new imports land as root-owned. Fix nightly. No plex group needed here.
if [[ -d /Volumes/Media/Ebooks/CalibreLibrary ]]; then
  chown -R will:will /Volumes/Media/Ebooks/CalibreLibrary
  chmod -R uog+rX,ug+w /Volumes/Media/Ebooks/CalibreLibrary
fi
