#!/usr/bin/env python3
"""update_containers — pull and restart Docker containers with new images.

Reads etc/willflix-services.conf to determine which services to upgrade.
Only services listed in the config (with upgrade != false) are updated.
Plex is skipped if active streams are detected (override with --force-plex).

Usage:
  update_containers              # normal nightly run
  update_containers --force-plex # update Plex regardless of active streams
  update_containers --dry-run    # show what would be updated, don't act
"""

import argparse
import json
import logging
import subprocess
import sys
import time
import urllib.request
from datetime import datetime
from pathlib import Path

import yaml

sys.path.insert(0, str(Path(__file__).resolve().parents[2]))
from lib import config, notify

logging.basicConfig(level=logging.INFO, format="%(message)s")
log = logging.getLogger(__name__)

REPO_DIR = Path(__file__).resolve().parents[2]
COMPOSE_FILE = "/willflix/docker/compose.yml"
SERVICES_CONFIG = REPO_DIR / "etc" / "willflix-services.conf"
MAINTENANCE_LOG = Path("/willflix/log/maintenance.log")

TAUTULLI_URL = "http://localhost:48181"


def load_services_config() -> dict:
    """Load willflix-services.conf and return the services dict."""
    with open(SERVICES_CONFIG) as f:
        data = yaml.safe_load(f)
    return data.get("services", {})


def plex_active_streams() -> int:
    """Return number of active Plex streams via Tautulli."""
    try:
        key = config.read_secret("tautulli_api_key")
        url = f"{TAUTULLI_URL}/api/v2?apikey={key}&cmd=get_activity"
        with urllib.request.urlopen(url, timeout=10) as r:
            data = json.loads(r.read())
        return int(data["response"]["data"].get("stream_count", 0))
    except Exception as e:
        log.warning(f"Could not check Plex sessions via Tautulli: {e}")
        return -1  # unknown — treat as busy to be safe


def get_container_image_id(service: str) -> str:
    """Return the image ID currently used by a running container.

    Tries both the service name (for containers with explicit container_name)
    and the default compose naming (docker-<service>-1).
    """
    for name in [service, f"docker-{service}-1"]:
        result = subprocess.run(
            ["docker", "inspect", "--format", "{{.Image}}", name],
            capture_output=True, text=True
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    return ""


def wait_for_running(service: str, timeout: int = 30) -> bool:
    """Poll until a container reaches 'running' state or timeout expires."""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        result = subprocess.run(
            ["docker", "inspect", "--format", "{{.State.Status}}", service],
            capture_output=True, text=True,
        )
        if result.returncode == 0 and result.stdout.strip() == "running":
            return True
        time.sleep(2)
    return False


def remove_container(service: str):
    """Force-remove any existing container that could conflict with this service.

    Compose can't stop/remove containers it doesn't own (no project labels),
    so we do it manually before asking compose to recreate.
    """
    for name in [service, f"docker-{service}-1"]:
        result = subprocess.run(
            ["docker", "rm", "-f", name],
            capture_output=True, text=True
        )
        if result.returncode == 0:
            return


def get_local_image_id(image: str) -> str:
    """Return the ID of a locally stored image (reflects latest pull)."""
    result = subprocess.run(
        ["docker", "image", "inspect", "--format", "{{.Id}}", image],
        capture_output=True, text=True
    )
    return result.stdout.strip()


def get_compose_service_images() -> dict[str, str]:
    """Return {service_name: image_name} from the merged compose config."""
    result = compose("config", "--format", "json", capture=True)
    if result.returncode != 0:
        return {}
    try:
        data = json.loads(result.stdout)
        return {
            svc: cfg["image"]
            for svc, cfg in data.get("services", {}).items()
            if "image" in cfg
        }
    except (json.JSONDecodeError, KeyError):
        return {}


def compose(*args, capture=False) -> subprocess.CompletedProcess:
    cmd = ["docker", "compose", "-f", COMPOSE_FILE] + list(args)
    return subprocess.run(cmd, capture_output=capture, text=True)


def get_services() -> list[str]:
    """Get all service names defined in the compose file."""
    result = compose("config", "--services", capture=True)
    return [s for s in result.stdout.strip().splitlines() if s]


def get_network_dependents() -> dict[str, list[str]]:
    """Return {service: [dependents]} for network_mode: "service:X" relationships."""
    result = compose("config", "--format", "json", capture=True)
    if result.returncode != 0:
        return {}
    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError:
        return {}
    deps: dict[str, list[str]] = {}
    for svc, cfg in data.get("services", {}).items():
        nm = cfg.get("network_mode", "")
        if nm.startswith("service:"):
            parent = nm.split(":", 1)[1]
            deps.setdefault(parent, []).append(svc)
    return deps


def log_maintenance(entries: list[str]):
    MAINTENANCE_LOG.parent.mkdir(parents=True, exist_ok=True)
    date = datetime.now().strftime("%Y-%m-%d")
    with MAINTENANCE_LOG.open("a") as f:
        for entry in entries:
            f.write(f"{date} update_containers  {entry}\n")


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--force-plex", action="store_true",
                        help="Update Plex even if streams are active")
    parser.add_argument("--dry-run", action="store_true",
                        help="Show what would be updated without acting")
    args = parser.parse_args()

    # Load service config to determine which services to upgrade
    svc_config = load_services_config()

    log.info("Pulling latest images...")
    if not args.dry_run:
        compose("pull", "--ignore-pull-failures")

    services = get_services()
    log.info(f"Found {len(services)} services")

    # Map service → image name so we can compare pulled vs running IDs
    svc_images = get_compose_service_images()

    # Track network_mode dependencies (e.g. qbittorrent → vpn)
    net_deps = get_network_dependents()
    # Services that use network_mode: service:X — need special handling on direct update
    net_mode_svcs = {dep for deps in net_deps.values() for dep in deps}

    # Decide Plex handling
    plex_skip_reason = None
    if not args.force_plex:
        streams = plex_active_streams()
        if streams > 0:
            plex_skip_reason = f"{streams} active stream(s)"
        elif streams < 0:
            plex_skip_reason = "could not verify sessions (treating as busy)"

    updated = []
    skipped = []
    failures = []

    for svc in services:
        # Only upgrade services listed in willflix-services.conf
        if svc not in svc_config:
            skipped.append(f"{svc} (unlisted)")
            continue

        # Skip services with upgrade: false
        if svc_config[svc].get("upgrade") is False:
            skipped.append(f"{svc} (pinned)")
            continue

        if svc == "plex" and plex_skip_reason:
            skipped.append(f"plex ({plex_skip_reason})")
            log.info(f"  Skipping plex: {plex_skip_reason}")
            continue

        # Check whether a new image is actually available
        image_name = svc_images.get(svc, "")
        if image_name:
            pulled_id = get_local_image_id(image_name)
            running_id = get_container_image_id(svc)
            if running_id and pulled_id and running_id == pulled_id:
                log.info(f"  Skipping {svc} (already up to date)")
                continue

        if args.dry_run:
            log.info(f"  Would update {svc}")
            updated.append(svc)
            continue

        log.info(f"  Updating {svc}...")
        remove_container(svc)
        if svc in net_mode_svcs:
            # This service shares another container's network namespace (network_mode: service:X).
            # --no-deps prevents compose from resolving that reference even when the parent is
            # running, causing "network service:X not found". Drop --no-deps so compose can
            # find the parent; drop --force-recreate since the container was just removed.
            result = compose("up", "-d", svc, capture=True)
        else:
            result = compose("up", "-d", "--no-deps", "--force-recreate", svc, capture=True)
        if result.returncode != 0:
            log.warning(f"  {svc} failed: {result.stderr.strip()[:200]}")
            failures.append((svc, result.stderr.strip()))
        else:
            updated.append(svc)
            # Recreate containers that share this service's network namespace,
            # since their network_mode reference breaks when the parent is recreated.
            for dep in net_deps.get(svc, []):
                log.info(f"  Restarting {dep} (network_mode: service:{svc})...")
                remove_container(dep)
                # Don't use --no-deps: compose must resolve network_mode: service:X,
                # which requires it to inspect the parent container's network namespace.
                # Don't use --force-recreate: container was just removed, so it's recreated anyway.
                dep_result = compose("up", "-d", dep, capture=True)
                if dep_result.returncode != 0:
                    log.warning(f"  {dep} failed: {dep_result.stderr.strip()[:200]}")
                    failures.append((dep, dep_result.stderr.strip()))
                else:
                    updated.append(dep)

    if not args.dry_run:
        # Remove containers for services that no longer exist in compose.yml
        log.info("Removing orphaned containers...")
        compose("up", "-d", "--remove-orphans", "--no-recreate")

    # Log and report
    if updated:
        log.info(f"\nUpdated: {', '.join(updated)}")
        if not args.dry_run:
            log_maintenance([f"Updated containers: {', '.join(updated)}"])
    else:
        log.info("\nNo containers had new images")

    if skipped:
        log.info(f"Skipped: {', '.join(skipped)}")
        if not args.dry_run and any("plex" in s for s in skipped):
            log_maintenance([f"Skipped plex: {plex_skip_reason}"])

    if updated and not args.dry_run:
        body = f"Updated: {', '.join(updated)}"
        if skipped:
            body += f"\nSkipped: {', '.join(skipped)}"
        if failures:
            failure_lines = "\n".join(f"  {svc}: {err[:200]}" for svc, err in failures)
            body += f"\nFailed ({len(failures)}):\n{failure_lines}"

            # Attempt LLM remediation (medium risk — always notify, append status)
            findings_text = (
                f"update_containers failures:\n"
                + "\n".join(f"  {svc}: {err[:400]}" for svc, err in failures)
            )
            remediate = None
            try:
                remediate = subprocess.run(
                    ["/willflix/bin/willflix-remediate",
                     "--script", "update_containers",
                     "--findings", findings_text],
                    capture_output=True, text=True, timeout=180,
                )
            except Exception:
                pass

            llm_note = ""
            if remediate is not None and remediate.returncode == 0:
                llm_note = "\n\n--- LLM auto-fix applied and verified ---"
            elif remediate is not None and remediate.stdout.strip():
                llm_note = f"\n\n--- LLM remediation attempt ---\n{remediate.stdout}"

            body += llm_note

        notify.send("INFO", "container-updates", f"Container updates: {len(updated)} on lafayette", body)


if __name__ == "__main__":
    main()
