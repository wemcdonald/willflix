#!/usr/bin/env python3
"""check_media_apps — monitor Sonarr, Radarr, and NZBGet for systematic errors.

Checks for failed imports, stuck queue items, disk space warnings, and
prolonged inactivity. Alerts on patterns, not individual failures.
"""

import json
import logging
import os
import subprocess
import sys
import urllib.request
from datetime import datetime, timedelta, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[2]))

from lib import config, notify

logging.basicConfig(level=logging.WARNING, format="%(message)s")
log = logging.getLogger(__name__)


def is_container_running(name: str) -> bool:
    """Return True if the named Docker container is in 'running' state."""
    try:
        result = subprocess.run(
            ["docker", "inspect", "--format", "{{.State.Status}}", name],
            capture_output=True, text=True, timeout=5,
        )
        return result.returncode == 0 and result.stdout.strip() == "running"
    except Exception:
        return False


def api_get(url: str, headers: dict = None, timeout: int = 15):
    """Make a GET request and return parsed JSON, or None on failure."""
    try:
        req = urllib.request.Request(url, headers=headers or {})
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read())
    except Exception as e:
        log.warning(f"API request failed: {url} — {e}")
        return None


class SonarrRadarrChecker:
    """Check Sonarr or Radarr (same v3 API)."""

    def __init__(self, name: str, base_url: str, api_key: str):
        self.name = name
        self.base_url = base_url.rstrip("/")
        self.headers = {"X-Api-Key": api_key}

    def _get(self, endpoint: str):
        return api_get(f"{self.base_url}/api/v3/{endpoint}", headers=self.headers)

    # Warnings that are handled automatically (e.g. by NZBGet StripExecutables)
    # and should not generate alerts.
    IGNORED_WARNINGS = {"Found executable file"}

    def check_queue_errors(self) -> list:
        """Find queue items with real errors or warnings.

        Skips items whose only status messages are in IGNORED_WARNINGS
        (e.g. "Found executable file" is handled by NZBGet StripExecutables).
        Uses trackedDownloadStatus rather than the raw download status field.
        """
        data = self._get("queue?pageSize=100&includeUnknownSeriesItems=true&includeUnknownMovieItems=true")
        if not data:
            return []

        records = data.get("records", [])
        errors = []
        for item in records:
            dl_status = item.get("trackedDownloadStatus", "")
            if dl_status not in ("warning", "error"):
                continue

            # Collect all message strings from statusMessages
            all_msgs = []
            for sm in item.get("statusMessages", []):
                all_msgs.extend(sm.get("messages", []))

            # Skip if every message is in the ignored set
            if all_msgs and all(m in self.IGNORED_WARNINGS for m in all_msgs):
                continue

            title = item.get("title", "Unknown")
            error_text = "; ".join(all_msgs) if all_msgs else dl_status
            errors.append({"title": title, "error": error_text, "status": dl_status})

        return errors

    def check_history_failures(self, hours: int = 24) -> list:
        """Find failed downloads and imports in recent history."""
        data = self._get("history?pageSize=200&sortKey=date&sortDirection=descending")
        if not data:
            return []

        cutoff = datetime.now(timezone.utc) - timedelta(hours=hours)
        failure_types = ("downloadFailed", "importFailed", "downloadImportIncomplete")
        failures = []

        for record in data.get("records", []):
            event_type = record.get("eventType", "")
            if event_type not in failure_types:
                continue

            date_str = record.get("date", "")
            try:
                record_date = datetime.fromisoformat(date_str.replace("Z", "+00:00"))
                if record_date < cutoff:
                    continue
            except (ValueError, TypeError):
                continue

            title = record.get("sourceTitle", "Unknown")
            data_detail = record.get("data", {})
            reason = data_detail.get("message", "") or event_type
            failures.append({"title": title, "reason": reason, "type": event_type})

        return failures

    def check_disk_space(self) -> list:
        """Check root folders for low disk space."""
        data = self._get("rootfolder")
        if not data:
            return []

        warnings = []
        for folder in data:
            free = folder.get("freeSpace", 0)
            path = folder.get("path", "unknown")
            free_gb = free / (1024 ** 3)
            if free_gb < 50:
                warnings.append(f"{path}: {free_gb:.1f}GB free")

        return warnings

    def check_health(self) -> list:
        """Check the app's built-in health endpoint."""
        data = self._get("health")
        if not data:
            return []
        return [
            {
                "type": h.get("type", ""),
                "message": h.get("message", ""),
                "source": h.get("source", ""),
                "wikiUrl": h.get("wikiUrl", ""),
            }
            for h in data
            if h.get("type") in ("warning", "error")
            and h.get("source") != "UpdateCheck"  # handled by nightly update_containers
        ]


class NZBGetChecker:
    """Check NZBGet for stuck or failed downloads."""

    def __init__(self, base_url: str):
        self.base_url = base_url.rstrip("/")

    def _rpc(self, method: str):
        url = f"{self.base_url}/jsonrpc"
        body = json.dumps({"method": method, "params": []}).encode()
        try:
            req = urllib.request.Request(url, data=body,
                                         headers={"Content-Type": "application/json"})
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = json.loads(resp.read())
            return data.get("result")
        except Exception as e:
            log.warning(f"NZBGet RPC failed ({method}): {e}")
            return None

    def check_failures(self) -> list:
        """Check recent history for failed downloads."""
        history = self._rpc("history")
        if not history:
            return []

        failures = []
        for item in history[:50]:  # Check last 50
            par_status = item.get("ParStatus", "")
            unpack_status = item.get("UnpackStatus", "")
            if par_status == "FAILURE" or unpack_status == "FAILURE":
                failures.append({
                    "name": item.get("Name", "Unknown"),
                    "par": par_status,
                    "unpack": unpack_status,
                })

        return failures

    def check_stuck(self) -> list:
        """Check for downloads stuck in post-processing or completed but not picked up."""
        history = self._rpc("history")
        if not history:
            return []

        stuck = []
        cutoff_hours = 12
        now = datetime.now(timezone.utc).timestamp()

        for item in history[:50]:
            status = item.get("Status", "")
            # Completed successfully but might not have been picked up
            if status == "SUCCESS/ALL":
                hist_time = item.get("HistoryTime", 0)
                age_hours = (now - hist_time) / 3600
                # If script status indicates it wasn't moved
                script_status = item.get("ScriptStatus", "")
                if script_status != "SUCCESS" and age_hours > cutoff_hours:
                    stuck.append({
                        "name": item.get("Name", "Unknown"),
                        "age_hours": int(age_hours),
                        "script_status": script_status,
                    })

        return stuck


def build_report(issues: dict) -> tuple:
    """Build alert subject and body from all issues found.

    Returns (subject, body) or (None, None) if no issues.
    """
    if not any(issues.values()):
        return None, None

    hostname = os.uname().nodename

    # Maps health check source names to the relevant settings page path.
    HEALTH_SOURCE_PATHS = {
        "NotificationStatusCheck": "/settings/connect",
        "NotificationStatus": "/settings/connect",
        "IndexerRssCheck": "/settings/indexers",
        "IndexerSearchCheck": "/settings/indexers",
        "IndexerStatusCheck": "/settings/indexers",
        "IndexerStatus": "/settings/indexers",
        "DownloadClientStatusCheck": "/settings/downloadclients",
        "DownloadClientCheck": "/settings/downloadclients",
        "DownloadClientStatus": "/settings/downloadclients",
        "ImportMechanismCheck": "/settings/mediamanagement",
        "RootFolderCheck": "/settings/mediamanagement",
        "MountCheck": "/settings/mediamanagement",
    }

    APP_BASE_URLS = {
        "Sonarr": "http://sonarr.willflix.org",
        "Radarr": "http://radarr.willflix.org",
    }

    parts = []
    total_issues = 0

    for app, app_issues in issues.items():
        if not app_issues:
            continue

        parts.append(f"--- {app} ---")
        base_url = APP_BASE_URLS.get(app, "")

        for category, items in app_issues.items():
            if not items:
                continue
            total_issues += len(items)
            parts.append(f"  {category} ({len(items)}):")
            for item in items[:10]:  # Cap at 10 per category
                if isinstance(item, dict):
                    detail = item.get("title") or item.get("name") or item.get("message", "")
                    reason = item.get("reason") or item.get("error") or ""
                    if reason:
                        parts.append(f"    - {detail}: {reason}")
                    else:
                        parts.append(f"    - {detail}")

                    # For health warnings, add a direct fix link and wiki URL
                    source = item.get("source", "")
                    wiki = item.get("wikiUrl", "")
                    settings_path = HEALTH_SOURCE_PATHS.get(source)
                    if base_url and settings_path:
                        parts.append(f"      Fix: {base_url}{settings_path}")
                    elif base_url and source:
                        parts.append(f"      Fix: {base_url}/system/status")
                    if wiki:
                        parts.append(f"      Docs: {wiki}")
                else:
                    parts.append(f"    - {item}")
            if len(items) > 10:
                parts.append(f"    ... and {len(items) - 10} more")
        parts.append("")

    subject = f"Media apps: {total_issues} issues on {hostname}"
    body = "\n".join(parts)
    body += "\nQuick links:\n"
    body += "  Sonarr queue:   http://sonarr.willflix.org/activity/queue\n"
    body += "  Sonarr health:  http://sonarr.willflix.org/system/status\n"
    body += "  Radarr queue:   http://radarr.willflix.org/activity/queue\n"
    body += "  Radarr health:  http://radarr.willflix.org/system/status\n"
    body += "  NZBGet:         http://nzbget.willflix.org"

    return subject, body


MAINTENANCE_LOG = Path("/willflix/log/maintenance.log")


def _log_issues(issues: dict):
    """Append a one-line summary per app to the maintenance log."""
    date = datetime.now().strftime("%Y-%m-%d")
    lines = []
    for app, app_issues in issues.items():
        if not app_issues:
            continue
        parts = [f"{cat} ({len(items)})" for cat, items in app_issues.items() if items]
        lines.append(f"{date} check_media_apps  {app}: {', '.join(parts)}\n")
    if lines:
        MAINTENANCE_LOG.parent.mkdir(parents=True, exist_ok=True)
        with MAINTENANCE_LOG.open("a") as f:
            f.writelines(lines)


def main():
    cfg = config.load_config()

    sonarr_url = cfg.get("SONARR_URL", "http://localhost:8989")
    radarr_url = cfg.get("RADARR_URL", "http://localhost:7878")
    nzbget_url = cfg.get("NZBGET_URL", "http://localhost:6789")
    failed_threshold = int(cfg.get("MEDIA_FAILED_IMPORT_THRESHOLD", "3"))

    try:
        sonarr_key = config.read_secret("sonarr_api_key")
    except FileNotFoundError:
        log.error("Sonarr API key not found in secrets")
        sonarr_key = None

    try:
        radarr_key = config.read_secret("radarr_api_key")
    except FileNotFoundError:
        log.error("Radarr API key not found in secrets")
        radarr_key = None

    issues = {}

    # If qbittorrent is already down, suppress the downstream health warnings it causes
    # in Radarr/Sonarr — those are noise when the container alert already covers it.
    qbit_running = is_container_running("qbittorrent")

    # Sonarr
    if sonarr_key:
        log.info("Checking Sonarr...")
        sonarr = SonarrRadarrChecker("Sonarr", sonarr_url, sonarr_key)
        sonarr_issues = {}

        queue_errors = sonarr.check_queue_errors()
        if queue_errors:
            sonarr_issues["queue errors"] = queue_errors

        history_failures = sonarr.check_history_failures()
        if len(history_failures) >= failed_threshold:
            sonarr_issues["failures (24h)"] = history_failures

        disk_warnings = sonarr.check_disk_space()
        if disk_warnings:
            sonarr_issues["disk space"] = disk_warnings

        health = sonarr.check_health()
        if not qbit_running:
            health = [h for h in health if "qBittorrent" not in h.get("message", "")]
        if health:
            sonarr_issues["health warnings"] = health

        if sonarr_issues:
            issues["Sonarr"] = sonarr_issues
            log.info(f"  Found {sum(len(v) for v in sonarr_issues.values())} issues")
        else:
            log.info("  OK")

    # Radarr
    if radarr_key:
        log.info("Checking Radarr...")
        radarr = SonarrRadarrChecker("Radarr", radarr_url, radarr_key)
        radarr_issues = {}

        queue_errors = radarr.check_queue_errors()
        if queue_errors:
            radarr_issues["queue errors"] = queue_errors

        history_failures = radarr.check_history_failures()
        if len(history_failures) >= failed_threshold:
            radarr_issues["failures (24h)"] = history_failures

        disk_warnings = radarr.check_disk_space()
        if disk_warnings:
            radarr_issues["disk space"] = disk_warnings

        health = radarr.check_health()
        if not qbit_running:
            health = [h for h in health if "qBittorrent" not in h.get("message", "")]
        if health:
            radarr_issues["health warnings"] = health

        if radarr_issues:
            issues["Radarr"] = radarr_issues
            log.info(f"  Found {sum(len(v) for v in radarr_issues.values())} issues")
        else:
            log.info("  OK")

    # NZBGet
    log.info("Checking NZBGet...")
    nzbget = NZBGetChecker(nzbget_url)
    nzbget_issues = {}

    failures = nzbget.check_failures()
    if len(failures) >= failed_threshold:
        nzbget_issues["download failures"] = failures

    stuck = nzbget.check_stuck()
    if stuck:
        nzbget_issues["stuck downloads"] = stuck

    if nzbget_issues:
        issues["NZBGet"] = nzbget_issues
        log.info(f"  Found {sum(len(v) for v in nzbget_issues.values())} issues")
    else:
        log.info("  OK")

    # Build and send alert
    subject, body = build_report(issues)
    if subject:
        severity = "WARNING"
        # Escalate to CRITICAL if disk space issues found
        if any("disk space" in (app_issues or {}) for app_issues in issues.values()):
            severity = "CRITICAL"

        # Attempt LLM remediation before alerting (low risk — suppress if fixed)
        remediate = None
        try:
            import subprocess as _sp
            remediate = _sp.run(
                ["/willflix/bin/willflix-remediate",
                 "--script", "check_media_apps",
                 "--findings", body],
                capture_output=True, text=True, timeout=180,
            )
        except Exception:
            pass  # fail safe: remediation failure must not block the alert

        if remediate is not None and remediate.returncode == 0:
            # Fixed and verified — suppress alert
            _log_issues(issues)
            return

        # Append LLM output to body if it added useful context
        final_body = body
        if remediate is not None and remediate.stdout.strip():
            final_body += f"\n\n--- Auto-remediation attempt ---\n{remediate.stdout}"

        notify.send(severity, "media-app-health", subject, final_body)
        _log_issues(issues)


if __name__ == "__main__":
    main()
