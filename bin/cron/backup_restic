#!/bin/bash
# backup_restic — config-driven restic backup to local + B2 offsite.
#
# Reads per-source config from /willflix/etc/backup.d/*.conf.
# Each source gets its own restic tag and retention policy.
#
# Schedule: daily 3:30am via cron

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NOTIFY="$(cd "$SCRIPT_DIR/.." && pwd)/willflix-notify"
MONITOR_STAMP="/var/tmp/willflix-monitors/backup_restic"
CONFIG_DIR="/willflix/etc/backup.d"
LOGFILE="/var/log/backup-restic.log"

LOCAL_REPO="/Volumes/Bonus1/lafayette"
REMOTE_REPO="b2:willflix-backup:lafayette"
PASSWORD_FILE="/willflix/secrets/restic_password"

export RESTIC_PASSWORD_FILE="$PASSWORD_FILE"
export B2_ACCOUNT_ID="$(cat /willflix/secrets/b2_account_id)"
export B2_ACCOUNT_KEY="$(cat /willflix/secrets/b2_application_key)"

# --- Helpers ---

log() {
    echo "$(date): $*" >> "$LOGFILE"
}

notify_failure() {
    local msg="$1"
    log "FAILURE: $msg"
    "$NOTIFY" --severity CRITICAL --key "backup-restic-fail" \
        --subject "Restic backup failed on $(hostname)" \
        --body "$msg

Check the log:
  tail -50 $LOGFILE"
}

# Parse a backup.d config file. Sets: PATHS, EXCLUDES, KEEP_DAILY, etc.
load_config() {
    local conf="$1"
    # Reset defaults
    PATHS=""
    EXCLUDES=""
    KEEP_DAILY=14
    KEEP_WEEKLY=8
    KEEP_MONTHLY=24
    OFFSITE=true

    # Source the config (it's bash-compatible)
    # shellcheck source=/dev/null
    source "$conf"
}

# Build --exclude flags from the EXCLUDES variable
build_excludes() {
    local flags=()
    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"  # trim leading whitespace
        line="${line%"${line##*[![:space:]]}"}"  # trim trailing whitespace
        [[ -z "$line" || "$line" == \#* ]] && continue
        flags+=(--exclude "$line")
    done <<< "$EXCLUDES"
    echo "${flags[@]}"
}

# Build --keep-* flags from retention config
build_forget_args() {
    local args=(
        --keep-daily "${KEEP_DAILY}"
        --keep-weekly "${KEEP_WEEKLY}"
        --keep-monthly "${KEEP_MONTHLY}"
    )
    [[ -n "${KEEP_LAST:-}" ]] && args+=(--keep-last "$KEEP_LAST")
    echo "${args[@]}"
}

# Run restic backup for one source against one repo
do_backup() {
    local repo="$1"
    local tag="$2"
    shift 2
    local -a paths=()
    local -a exclude_flags=()

    # Parse PATHS (space-separated, but respect quotes)
    eval "paths=($PATHS)"

    # Build exclude flags (noglob prevents pattern expansion)
    set -f
    while IFS= read -r line; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" || "$line" == \#* ]] && continue
        exclude_flags+=(--exclude "$line")
    done <<< "$EXCLUDES"
    set +f

    restic -r "$repo" backup \
        "${paths[@]}" \
        "${exclude_flags[@]}" \
        --tag "$tag" \
        --no-scan \
        --cleanup-cache \
        >> "$LOGFILE" 2>&1
}

# Apply retention for a tag against one repo
do_forget() {
    local repo="$1"
    local tag="$2"

    restic -r "$repo" forget \
        --tag "$tag" \
        --keep-daily "${KEEP_DAILY}" \
        --keep-weekly "${KEEP_WEEKLY}" \
        --keep-monthly "${KEEP_MONTHLY}" \
        --prune \
        >> "$LOGFILE" 2>&1
}

# --- Main ---

log "=== Starting restic backup ==="

FAILED=0

for conf in "$CONFIG_DIR"/*.conf; do
    [[ -f "$conf" ]] || continue
    tag="$(basename "$conf" .conf)"
    load_config "$conf"

    if [[ -z "$PATHS" ]]; then
        log "Skipping $tag: no PATHS defined"
        continue
    fi

    # Local backup
    log "[$tag] Backing up to local repo"
    if do_backup "$LOCAL_REPO" "$tag"; then
        log "[$tag] Local backup complete"
        do_forget "$LOCAL_REPO" "$tag" || log "[$tag] Local forget/prune failed (non-fatal)"
    else
        log "[$tag] Local backup FAILED"
        notify_failure "Local backup failed for source: $tag"
        FAILED=1
        continue  # Skip offsite if local failed
    fi

    # Offsite backup (if enabled)
    if [[ "$OFFSITE" == "true" ]]; then
        log "[$tag] Backing up to B2"
        if do_backup "$REMOTE_REPO" "$tag"; then
            log "[$tag] B2 backup complete"
            do_forget "$REMOTE_REPO" "$tag" || log "[$tag] B2 forget/prune failed (non-fatal)"
        else
            log "[$tag] B2 backup FAILED"
            notify_failure "B2 backup failed for source: $tag"
            FAILED=1
        fi
    fi
done

if [[ "$FAILED" -eq 0 ]]; then
    log "=== All backups completed successfully ==="
else
    log "=== Some backups failed — check above ==="
fi

# Touch freshness stamp (even if some failed — the script itself ran)
install -d -m 1777 "$(dirname "$MONITOR_STAMP")"
touch "$MONITOR_STAMP"
