{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["bunx", "@playwright/mcp@latest", "--headless", "--executable-path", "/opt/google/chrome/chrome"],
      "enabled": true
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/sse",
      "enabled": true
    }
  }
}
