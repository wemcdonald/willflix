# ================================
# DOCKER APPDATA SELECTIVE TRACKING  
# Exclude most directories, include configs
# ================================

# =============================================================================
# EXCLUDE MOST APP DIRECTORIES (data-heavy)
# =============================================================================
audiobookshelf/
calibre-*/
healthbot/
jdownloader/
nextcloud*/
postgres/
qBittorrent/
radarr/
redis/
sonarr/
vnc/
nzbget/
letsencrypt/
prowlarr/
lidarr/

# =============================================================================
# INCLUDE THESE DIRECTORIES ENTIRELY
# =============================================================================
!authentik/
!nginx-*/
!smtp-relay/

# =============================================================================
# SELECTIVELY INCLUDE CONFIGS FROM EXCLUDED DIRS
# =============================================================================

# Nextcloud configuration
!nextcloud/config/
!nextcloud/config/**

# Calibre-web email templates
!calibre-web-automated/cps/templates/
!calibre-web-automated/cps/templates/**

# JDownloader settings
!jdownloader/cfg/
!jdownloader/cfg/**

# App config files
!*/config.xml
!*/*.conf
!*/categories.json
!*/watched_folders.json

# =============================================================================
# EXCLUDE SENSITIVE/DATA FILES FROM INCLUDED DIRS
# =============================================================================

# Even in included dirs, exclude sensitive data
authentik/media/
authentik/certs/
nginx-*/logs/
nginx-*/log/
smtp-relay/logs/
ofelia/logs/
